# ── Data (never baked into the image) ────────────────────────────────────────
data/

# ── Git & IDE ─────────────────────────────────────────────────────────────────
.git/
.github/
.gitignore

# ── Notebooks & exploratory figures ──────────────────────────────────────────
notebooks/
figures/

# ── Python cache ─────────────────────────────────────────────────────────────
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
*.egg-info/
.eggs/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Local env / secrets ───────────────────────────────────────────────────────
.env
*.env

# ── Misc ──────────────────────────────────────────────────────────────────────
*.md
*.log
.DS_Store
Thumbs.db
